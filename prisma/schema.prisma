generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model cartitem {
  id        BigInt  @id @default(autoincrement())
  orderid   BigInt
  productid BigInt
  quantity  Int
  subtotal  Decimal @db.Decimal(10, 2)
  orders    orders  @relation(fields: [orderid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_order")
  product   product @relation(fields: [productid], references: [id], onUpdate: NoAction, map: "fk_product")
}

model customer {
  id        BigInt    @id @default(autoincrement())
  fullname  String    @db.VarChar(255)
  email     String    @unique @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  address   String?
  createdat DateTime? @default(now()) @db.Timestamp(6)
  orders    orders[]
}

model orders {
  id         BigInt     @id @default(autoincrement())
  customerid BigInt
  total      Decimal    @db.Decimal(10, 2)
  status     String?    @default("PENDING") @db.VarChar(50)
  createdat  DateTime?  @default(now()) @db.Timestamp(6)
  cartitem   cartitem[]
  customer   customer   @relation(fields: [customerid], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "fk_customer")
}

model product {
  id          BigInt     @id @default(autoincrement())
  name        String     @db.VarChar(255)
  description String?
  price       Decimal    @db.Decimal(10, 2)
  imageurl    String
  materials   String?    @db.VarChar(255)
  stock       Int?       @default(0)
  createdat   DateTime?  @default(now()) @db.Timestamp(6)
  cartitem    cartitem[]
}
